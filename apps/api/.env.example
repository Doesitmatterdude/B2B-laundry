# ---- FreshFold API environment (copy to .env, fill values; NEVER commit .env) ----
NODE_ENV=development
PORT=3000

# Database (Cloud SQL Postgres or local)
DATABASE_URL=postgresql://freshfold:freshfold@localhost:5432/freshfold?schema=public

# Redis (Memorystore or local)
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_TTL=900          # 15 min (seconds)
JWT_REFRESH_TTL=2592000     # 30 days (seconds)

# Google Cloud Storage (evidence/PDFs)
GCS_BUCKET=freshfold-evidence
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcs-sa.json

# Aerolink Claude API (server-side AI module — DO NOT expose to clients)
# Rotate the key if it was ever shared in plaintext.
AEROLINK_BASE_URL=https://capi.aerolink.lat
AEROLINK_API_KEY=__set_in_secret_manager__

# Notification providers
WHATSAPP_TOKEN=
SMS_API_KEY=
SMTP_URL=
